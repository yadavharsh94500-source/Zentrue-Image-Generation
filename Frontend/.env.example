# ─── Backend API URL ──────────────────────────────────────────
# EXPO_PUBLIC_ prefix is required for Expo to expose this to the app

# Local development (use your machine's local IP, not localhost)
EXPO_PUBLIC_API_URL=http://192.168.1.100:5000

# Production (uncomment when deployed)
# EXPO_PUBLIC_API_URL=https://your-app.onrender.com
